{
  "name": "clinica",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "dev:backend": "PORT=3001 node --watch server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "node server.js",
    "preview": "npm run preview --prefix frontend",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:starter": "playwright test --config=./testing/playwright/playwright.config.js",
    "test:e2e:starter:headed": "playwright test --headed --config=./testing/playwright/playwright.config.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
